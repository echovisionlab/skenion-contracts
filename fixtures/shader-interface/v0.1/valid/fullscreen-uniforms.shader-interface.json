{
  "schema": "skenion.shader.interface",
  "schemaVersion": "0.1.0",
  "language": "wgsl",
  "uniforms": [
    {
      "id": "speed",
      "label": "Speed",
      "type": {
        "flow": "control",
        "dataKind": "value.core.float32",
        "format": "f32",
        "range": {
          "min": 0,
          "max": 2,
          "step": 0.01
        }
      },
      "default": 0.5,
      "required": false
    },
    {
      "id": "enabled",
      "label": "Enabled",
      "type": {
        "flow": "control",
        "dataKind": "value.core.bool"
      },
      "default": true,
      "required": false
    },
    {
      "id": "iterations",
      "label": "Iterations",
      "type": {
        "flow": "control",
        "dataKind": "value.core.int32",
        "format": "i32"
      },
      "default": 8,
      "required": false
    },
    {
      "id": "tint",
      "label": "Tint",
      "type": {
        "flow": "control",
        "dataKind": "value.core.color",
        "format": "rgba32f",
        "colorSpace": "linear"
      },
      "default": [
        1,
        0.2,
        0.1,
        1
      ],
      "required": false
    }
  ]
}
