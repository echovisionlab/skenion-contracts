{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skenion.dev/schemas/graph/v0/graph.schema.json",
  "title": "Skenion Graph Document",
  "type": "object",
  "required": ["schema", "schemaVersion", "id", "revision", "nodes", "edges"],
  "properties": {
    "schema": {
      "const": "skenion.graph"
    },
    "schemaVersion": {
      "const": "0.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "kind", "params"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {
          "$ref": "#/$defs/portRef"
        },
        "to": {
          "$ref": "#/$defs/portRef"
        }
      },
      "additionalProperties": false
    },
    "portRef": {
      "type": "object",
      "required": ["node", "port"],
      "properties": {
        "node": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
