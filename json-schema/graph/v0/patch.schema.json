{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skenion.dev/schemas/graph/v0/patch.schema.json",
  "title": "Skenion Graph Patch",
  "type": "object",
  "required": ["schema", "schemaVersion", "baseRevision", "ops"],
  "properties": {
    "schema": {
      "const": "skenion.graph.patch"
    },
    "schemaVersion": {
      "const": "0.0.0"
    },
    "baseRevision": {
      "type": "string",
      "minLength": 1
    },
    "ops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op"],
        "properties": {
          "op": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
