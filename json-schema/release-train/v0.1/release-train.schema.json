          "$ref": "#/$defs/checksumGate"
        },
        "runtime-smoke": {
          "$ref": "#/$defs/runtime-smokeGateMap"
        },
        "studio-package-smoke": {
          "$ref": "#/$defs/studio-package-smokeGateMap"
        },
        "examples-conformance": {
          "$ref": "#/$defs/examples-conformanceGate"
        },
        "docs-pages-deployment": {
          "$ref": "#/$defs/docs-pages-deploymentGate"
        }
      },
      "additionalProperties": false
    },
    "registryPackageGates": {
      "type": "object",
      "required": [
        "contracts-npm",
        "contracts-crate",
        "sdk-npm"
      ],
      "properties": {
        "contracts-npm": {
          "$ref": "#/$defs/registryPackageGate"
        },
        "contracts-crate": {
          "$ref": "#/$defs/registryPackageGate"
        },
        "sdk-npm": {
          "$ref": "#/$defs/registryPackageGate"
        }
      },
      "additionalProperties": false
    },
    "registryPackageGate": {
      "type": "object",
      "required": [
        "id",
        "status",
        "required",
        "package"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
        "package": {
          "$ref": "#/$defs/registryPackage"
        },
        "evidence-url": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "githubReleaseAssetGates": {
      "type": "object",
      "required": [
        "runtime",
        "studio"
      ],
      "properties": {
        "runtime": {
          "$ref": "#/$defs/artifactCollectionGate"
        },
        "studio": {
          "$ref": "#/$defs/artifactCollectionGate"
        }
      },
      "additionalProperties": false
    },
    "artifactCollectionGate": {
      "type": "object",
      "required": [
        "id",
        "status",
        "required",
        "repository",
        "tag",
        "artifact-ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "artifact-ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "evidence-url": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "checksumGate": {
      "type": "object",
      "required": [
        "id",
        "status",
        "required",
        "artifact-ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
        "artifact-ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "expected-checksums": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/checksum"
          }
        },
        "evidence-url": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "runtime-smokeGateMap": {
      "type": "object",
