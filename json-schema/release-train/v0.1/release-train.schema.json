      "type": "object",
      "required": [
        "registry-packages",
        "github-release-assets",
        "checksum-verification",
        "runtime-smoke",
        "studio-package-smoke",
        "examples-conformance",
        "docs-pages-deployment"
      ],
      "properties": {
        "registry-packages": {
          "$ref": "#/$defs/registryPackageGates"
        },
        "github-release-assets": {
          "$ref": "#/$defs/githubReleaseAssetGates"
        },
