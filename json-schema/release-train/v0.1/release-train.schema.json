          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "desktop-package-artifact-id": {
          "type": "string",
          "minLength": 1
