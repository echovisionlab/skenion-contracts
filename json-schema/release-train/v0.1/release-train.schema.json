    "examples-conformanceGate": {
      "type": "object",
      "required": [
        "id",
        "status",
        "required",
        "repository",
        "ref",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
