{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skenion.dev/schemas/release-train/v0.1/release-train.schema.json",
  "title": "skenion Release Train Manifest v0.1",
  "type": "object",
  "required": [
    "schema",
    "schema-version",
    "train-id",
    "train-version",
    "protocol-baselines",
    "capability-set",
    "components",
    "release-gates"
  ],
  "properties": {
    "schema": {
      "const": "skenion.release-train"
    },
    "schema-version": {
      "const": "0.1.0"
    },
    "train-id": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "train-version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "protocol-baselines": {
      "$ref": "#/$defs/protocol-baselines"
    },
    "capability-set": {
      "$ref": "#/$defs/capability-set"
    },
    "components": {
      "$ref": "#/$defs/components"
    },
    "release-gates": {
      "$ref": "#/$defs/release-gates"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "protocol-baselines": {
      "type": "object",
      "required": [
        "graph",
        "project",
        "node",
        "extension",
        "runtime-http",
        "runtime-collaboration"
      ],
      "properties": {
        "graph": {
          "const": "0.1"
        },
        "project": {
          "const": "0.1"
        },
        "node": {
          "const": "0.1"
        },
        "extension": {
          "const": "0.1"
        },
        "runtime-http": {
          "const": "v0"
        },
        "runtime-collaboration": {
          "const": "v0"
        }
      },
      "additionalProperties": false
    },
    "capability-set": {
      "type": "object",
      "required": [
        "protocol-surfaces",
        "runtime",
        "studio",
        "marketplace",
        "manual"
      ],
      "properties": {
        "protocol-surfaces": {
          "$ref": "#/$defs/protocol-baselines"
        },
        "runtime": {
          "$ref": "#/$defs/runtimeCapabilitySet"
        },
        "studio": {
          "$ref": "#/$defs/studioCapabilitySet"
        },
        "marketplace": {
          "$ref": "#/$defs/marketplaceCapabilitySet"
        },
        "manual": {
          "$ref": "#/$defs/manualCapabilitySet"
        }
      },
      "additionalProperties": false
    },
    "runtimeCapabilitySet": {
      "type": "object",
      "required": [
        "session-addressing",
        "event-replay",
        "multi-window",
        "connection-profiles",
        "collaboration",
        "operation-log",
        "io-discovery",
        "auth-policy"
      ],
      "properties": {
        "session-addressing": {
          "const": true
        },
        "event-replay": {
          "const": true
        },
        "multi-window": {
          "const": true
        },
        "connection-profiles": {
          "type": "array",
          "items": {
            "enum": [
              "local-managed",
              "local-shared",
              "remote"
            ]
          },
          "minItems": 3,
          "uniqueItems": true
        },
        "collaboration": {
          "const": "server-authoritative-ot"
        },
        "operation-log": {
          "const": true
        },
        "io-discovery": {
          "const": "raw-descriptor"
        },
        "auth-policy": {
          "const": "deferred"
        }
      },
      "additionalProperties": false
    },
    "studioCapabilitySet": {
      "type": "object",
      "required": [
        "graph-editor",
        "patch-library",
        "subpatches",
        "living-help",
        "graph-clipboard",
        "desktop-shell",
        "connection-profiles"
      ],
      "properties": {
        "graph-editor": {
          "const": true
        },
        "patch-library": {
          "const": true
        },
        "subpatches": {
          "const": true
        },
        "living-help": {
          "const": true
        },
        "graph-clipboard": {
          "const": true
        },
        "desktop-shell": {
          "const": "tauri"
        },
        "connection-profiles": {
          "type": "array",
          "items": {
            "enum": [
              "local-managed",
              "local-shared",
              "remote"
            ]
          },
          "minItems": 3,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "marketplaceCapabilitySet": {
      "type": "object",
      "required": [
        "package-discovery",
        "package-install",
        "package-update",
        "extension-packages"
      ],
      "properties": {
        "package-discovery": {
          "const": true
        },
        "package-install": {
          "const": true
        },
        "package-update": {
          "const": true
        },
        "extension-packages": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "manualCapabilitySet": {
      "type": "object",
      "required": [
        "versioned-paths",
        "pages-deployment",
        "latest-promotion-requires-matrix",
        "patch-releases-use-major-minor-path"
      ],
      "properties": {
        "versioned-paths": {
          "const": true
        },
        "pages-deployment": {
          "const": true
        },
        "latest-promotion-requires-matrix": {
          "const": true
        },
        "patch-releases-use-major-minor-path": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "components": {
      "type": "object",
      "required": [
        "contracts",
        "runtime",
        "sdk",
        "studio",
        "examples",
        "docs"
      ],
      "properties": {
        "contracts": {
          "$ref": "#/$defs/contractsComponent"
        },
        "runtime": {
          "$ref": "#/$defs/runtimeComponent"
        },
        "sdk": {
          "$ref": "#/$defs/sdkComponent"
        },
        "studio": {
          "$ref": "#/$defs/studioComponent"
        },
        "examples": {
          "$ref": "#/$defs/examplesComponent"
        },
        "docs": {
          "$ref": "#/$defs/docsComponent"
        }
      },
      "additionalProperties": false
    },
    "contractsComponent": {
      "type": "object",
      "required": [
        "npm",
        "crate"
      ],
      "properties": {
        "npm": {
          "$ref": "#/$defs/registryPackage"
        },
        "crate": {
          "$ref": "#/$defs/registryPackage"
        }
      },
      "additionalProperties": false
    },
    "runtimeComponent": {
      "type": "object",
      "required": [
        "binaries"
      ],
      "properties": {
        "binaries": {
          "$ref": "#/$defs/runtimeBinaryArtifactMap"
        }
      },
      "additionalProperties": false
    },
    "sdkComponent": {
      "type": "object",
      "required": [
        "npm"
      ],
      "properties": {
        "npm": {
          "$ref": "#/$defs/registryPackage"
        }
      },
      "additionalProperties": false
    },
    "studioComponent": {
      "type": "object",
      "required": [
        "web-bundle",
        "desktop-packages",
        "runtime-sidecars"
      ],
      "properties": {
        "web-bundle": {
          "$ref": "#/$defs/studioWebBundleArtifact"
        },
        "desktop-packages": {
          "$ref": "#/$defs/studioDesktopArtifactMap"
        },
        "runtime-sidecars": {
          "$ref": "#/$defs/studioRuntimeSidecarArtifactMap"
        }
      },
      "additionalProperties": false
    },
    "examplesComponent": {
      "type": "object",
      "required": [
        "repository",
        "version",
        "tag"
      ],
      "properties": {
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "docsComponent": {
      "type": "object",
      "required": [
        "manual"
      ],
      "properties": {
        "manual": {
          "$ref": "#/$defs/manualComponent"
        }
      },
      "additionalProperties": false
    },
    "manualComponent": {
      "type": "object",
      "required": [
        "version",
        "path",
        "pages-url"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/version"
        },
        "path": {
          "type": "string",
          "pattern": "^/manual/[0-9]+\\.[0-9]+/$"
        },
        "pages-url": {
          "type": "string",
          "pattern": "^https://skenion\\.github\\.io/skenion-docs/manual/[0-9]+\\.[0-9]+/$"
        }
      },
      "additionalProperties": false
    },
    "registryPackage": {
      "type": "object",
      "required": [
        "ecosystem",
        "name",
        "version"
      ],
      "properties": {
        "ecosystem": {
          "enum": [
            "npm",
            "crates.io"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "url": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "runtimeBinaryArtifactMap": {
      "type": "object",
      "required": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ],
      "properties": {
        "aarch64-apple-darwin": {
          "$ref": "#/$defs/runtimeBinaryAarch64AppleDarwin"
        },
        "x86_64-apple-darwin": {
          "$ref": "#/$defs/runtimeBinaryX8664AppleDarwin"
        },
        "x86_64-pc-windows-msvc": {
          "$ref": "#/$defs/runtimeBinaryX8664WindowsMsvc"
        },
        "aarch64-pc-windows-msvc": {
          "$ref": "#/$defs/runtimeBinaryAarch64WindowsMsvc"
        },
        "x86_64-unknown-linux-gnu": {
          "$ref": "#/$defs/runtimeBinaryX8664LinuxGnu"
        },
        "aarch64-unknown-linux-gnu": {
          "$ref": "#/$defs/runtimeBinaryAarch64LinuxGnu"
        }
      },
      "additionalProperties": false
    },
    "studioDesktopArtifactMap": {
      "type": "object",
      "required": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ],
      "properties": {
        "aarch64-apple-darwin": {
          "$ref": "#/$defs/studioDesktopAarch64AppleDarwin"
        },
        "x86_64-apple-darwin": {
          "$ref": "#/$defs/studioDesktopX8664AppleDarwin"
        },
        "x86_64-pc-windows-msvc": {
          "$ref": "#/$defs/studioDesktopX8664WindowsMsvc"
        },
        "aarch64-pc-windows-msvc": {
          "$ref": "#/$defs/studioDesktopAarch64WindowsMsvc"
        },
        "x86_64-unknown-linux-gnu": {
          "$ref": "#/$defs/studioDesktopX8664LinuxGnu"
        },
        "aarch64-unknown-linux-gnu": {
          "$ref": "#/$defs/studioDesktopAarch64LinuxGnu"
        }
      },
      "additionalProperties": false
    },
    "studioRuntimeSidecarArtifactMap": {
      "type": "object",
      "required": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ],
      "properties": {
        "aarch64-apple-darwin": {
          "$ref": "#/$defs/studioRuntimeSidecarAarch64AppleDarwin"
        },
        "x86_64-apple-darwin": {
          "$ref": "#/$defs/studioRuntimeSidecarX8664AppleDarwin"
        },
        "x86_64-pc-windows-msvc": {
          "$ref": "#/$defs/studioRuntimeSidecarX8664WindowsMsvc"
        },
        "aarch64-pc-windows-msvc": {
          "$ref": "#/$defs/studioRuntimeSidecarAarch64WindowsMsvc"
        },
        "x86_64-unknown-linux-gnu": {
          "$ref": "#/$defs/studioRuntimeSidecarX8664LinuxGnu"
        },
        "aarch64-unknown-linux-gnu": {
          "$ref": "#/$defs/studioRuntimeSidecarAarch64LinuxGnu"
        }
      },
      "additionalProperties": false
    },
    "runtimeBinaryAarch64AppleDarwin": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64AppleDarwinReleaseBlocking"
        },
        {
          "$ref": "#/$defs/runtimeBinaryKind"
        }
      ]
    },
    "runtimeBinaryX8664AppleDarwin": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664AppleDarwinReleaseBlocking"
        },
        {
          "$ref": "#/$defs/runtimeBinaryKind"
        }
      ]
    },
    "runtimeBinaryX8664WindowsMsvc": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664WindowsMsvcReleaseBlocking"
        },
        {
          "$ref": "#/$defs/runtimeBinaryKind"
        }
      ]
    },
    "runtimeBinaryAarch64WindowsMsvc": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64WindowsMsvcPreview"
        },
        {
          "$ref": "#/$defs/runtimeBinaryKind"
        }
      ]
    },
    "runtimeBinaryX8664LinuxGnu": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664LinuxGnuReleaseBlocking"
        },
        {
          "$ref": "#/$defs/runtimeBinaryKind"
        }
      ]
    },
    "runtimeBinaryAarch64LinuxGnu": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64LinuxGnuPreview"
        },
        {
          "$ref": "#/$defs/runtimeBinaryKind"
        }
      ]
    },
    "studioDesktopAarch64AppleDarwin": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64AppleDarwinReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioDesktopKind"
        }
      ]
    },
    "studioDesktopX8664AppleDarwin": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664AppleDarwinReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioDesktopKind"
        }
      ]
    },
    "studioDesktopX8664WindowsMsvc": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664WindowsMsvcReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioDesktopKind"
        }
      ]
    },
    "studioDesktopAarch64WindowsMsvc": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64WindowsMsvcPreview"
        },
        {
          "$ref": "#/$defs/studioDesktopKind"
        }
      ]
    },
    "studioDesktopX8664LinuxGnu": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664LinuxGnuReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioDesktopKind"
        }
      ]
    },
    "studioDesktopAarch64LinuxGnu": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64LinuxGnuPreview"
        },
        {
          "$ref": "#/$defs/studioDesktopKind"
        }
      ]
    },
    "studioRuntimeSidecarAarch64AppleDarwin": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64AppleDarwinReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioRuntimeSidecarKind"
        }
      ]
    },
    "studioRuntimeSidecarX8664AppleDarwin": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664AppleDarwinReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioRuntimeSidecarKind"
        }
      ]
    },
    "studioRuntimeSidecarX8664WindowsMsvc": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664WindowsMsvcReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioRuntimeSidecarKind"
        }
      ]
    },
    "studioRuntimeSidecarAarch64WindowsMsvc": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64WindowsMsvcPreview"
        },
        {
          "$ref": "#/$defs/studioRuntimeSidecarKind"
        }
      ]
    },
    "studioRuntimeSidecarX8664LinuxGnu": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/x8664LinuxGnuReleaseBlocking"
        },
        {
          "$ref": "#/$defs/studioRuntimeSidecarKind"
        }
      ]
    },
    "studioRuntimeSidecarAarch64LinuxGnu": {
      "allOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "$ref": "#/$defs/aarch64LinuxGnuPreview"
        },
        {
          "$ref": "#/$defs/studioRuntimeSidecarKind"
        }
      ]
    },
    "studioWebBundleArtifact": {
      "allOf": [
        {
          "$ref": "#/$defs/nonTargetArtifact"
        },
        {
          "$ref": "#/$defs/studioWebBundleKind"
        }
      ]
    },
    "aarch64AppleDarwinReleaseBlocking": {
      "type": "object",
      "properties": {
        "target": {
          "const": "aarch64-apple-darwin"
        },
        "support-tier": {
          "const": "release-blocking"
        }
      }
    },
    "x8664AppleDarwinReleaseBlocking": {
      "type": "object",
      "properties": {
        "target": {
          "const": "x86_64-apple-darwin"
        },
        "support-tier": {
          "const": "release-blocking"
        }
      }
    },
    "x8664WindowsMsvcReleaseBlocking": {
      "type": "object",
      "properties": {
        "target": {
          "const": "x86_64-pc-windows-msvc"
        },
        "support-tier": {
          "const": "release-blocking"
        }
      }
    },
    "aarch64WindowsMsvcPreview": {
      "type": "object",
      "properties": {
        "target": {
          "const": "aarch64-pc-windows-msvc"
        },
        "support-tier": {
          "const": "preview"
        }
      }
    },
    "x8664LinuxGnuReleaseBlocking": {
      "type": "object",
      "properties": {
        "target": {
          "const": "x86_64-unknown-linux-gnu"
        },
        "support-tier": {
          "const": "release-blocking"
        }
      }
    },
    "aarch64LinuxGnuPreview": {
      "type": "object",
      "properties": {
        "target": {
          "const": "aarch64-unknown-linux-gnu"
        },
        "support-tier": {
          "const": "preview"
        }
      }
    },
    "runtimeBinaryKind": {
      "type": "object",
      "properties": {
        "kind": {
          "const": "runtime-binary"
        }
      }
    },
    "studioDesktopKind": {
      "type": "object",
      "properties": {
        "kind": {
          "const": "studio-desktop-package"
        }
      }
    },
    "studioRuntimeSidecarKind": {
      "type": "object",
      "properties": {
        "kind": {
          "const": "studio-runtime-sidecar"
        }
      }
    },
    "studioWebBundleKind": {
      "type": "object",
      "properties": {
        "kind": {
          "const": "studio-web-bundle"
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": [
        "id",
        "target",
        "support-tier",
        "kind",
        "name",
        "version",
        "source",
        "checksum",
        "size-bytes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "support-tier": {
          "enum": [
            "release-blocking",
            "preview"
          ]
        },
        "kind": {
          "enum": [
            "runtime-binary",
            "studio-desktop-package",
            "studio-runtime-sidecar"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "source": {
          "$ref": "#/$defs/artifactSource"
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "size-bytes": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "nonTargetArtifact": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "name",
        "version",
        "source",
        "checksum",
        "size-bytes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "studio-web-bundle"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "source": {
          "$ref": "#/$defs/artifactSource"
        },
        "checksum": {
          "$ref": "#/$defs/checksum"
        },
        "size-bytes": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "artifactSource": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "repository",
            "tag",
            "asset-name",
            "url"
          ],
          "properties": {
            "kind": {
              "const": "github-release-asset"
            },
            "repository": {
              "$ref": "#/$defs/repository"
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "asset-name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "oneOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind",
            "url"
          ],
          "properties": {
            "kind": {
              "const": "url"
            },
            "url": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "checksum": {
      "type": "object",
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "value": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
