    "repository": {
      "type": "string",
      "pattern": "^skenion/[A-Za-z0-9_.-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
